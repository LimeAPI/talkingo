# ─── Talkingo Web App — Environment Variables ─────────────────────────────────
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ─── Google OAuth ──────────────────────────────────────────────────────────────
# Required for sign-in with Google. Create credentials in Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Add the redirect URI: https://yourdomain.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ─── Facebook OAuth ────────────────────────────────────────────────────────────
# Required for sign-in with Facebook. Create an app in the Meta Developer console:
# https://developers.facebook.com/apps  → add "Facebook Login" product.
# Under Facebook Login → Settings, add these Valid OAuth Redirect URIs:
#   https://yourdomain.com/api/auth/facebook/callback
#   http://localhost:3000/api/auth/facebook/callback   (for local dev)
FACEBOOK_CLIENT_ID=your_facebook_app_id_here
FACEBOOK_CLIENT_SECRET=your_facebook_app_secret_here

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Server-side only (no NEXT_PUBLIC_ prefix)
GEMINI_API_KEY=your_gemini_api_key_here

# Model overrides. The text-chat route has a built-in fallback chain, but the
# live-voice proxy and TTS use a SINGLE model with no fallback — if the default
# model name is not enabled for your API key, the live call / voice notes will
# fail. Pin these to a model you have confirmed access to before launch.
#   - GEMINI_LIVE_MODEL: bidi live-audio model used by the WS voice proxy
#   - NEXT_PUBLIC_AI_MODEL: primary text model (first entry in the chat chain)
# GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-09-2025
# NEXT_PUBLIC_AI_MODEL=gemini-2.5-flash

# ─── Live-voice daily cap ─────────────────────────────────────────────────────
# The live proxy ALWAYS meters daily live-voice seconds per user (server-side,
# collection `live_usage_daily`). This flag controls whether that metering is
# ENFORCED (connect gate + graceful wind-down + disconnect) or runs in SHADOW
# mode (meter + log only). Ship in shadow mode, review real usage, then flip.
# Caps are resolved per plan in src/lib/subscription/live-limits.ts
# (trial: 10 min/day, active: 20 min/day).
# LIVE_CAP_ENFORCE=false

# ─── Appwrite ─────────────────────────────────────────────────────────────────
# Public (needed by client SDK)
NEXT_PUBLIC_APPWRITE_ENDPOINT=your_appwrite_endpoint_here
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here

# Server-side only (admin API key for webhook/notifications)
APPWRITE_API_KEY=your_appwrite_api_key_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Server-side only — required, validated at startup. App will throw on launch
# if any of these are missing or contain placeholder values.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Publishable key (pk_test_... / pk_live_...). Safe to expose to the browser.
# Only needed if you add client-side Stripe.js/Elements; hosted Checkout works
# without it. Created products/prices via: npm run stripe:setup
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (different for test vs live mode)
# NOTE: Stripe subscriptions reference PRICE ids (price_...). This is distinct
# from DodoPayments below, which uses PRODUCT ids (pdt_...).
STRIPE_PRICE_TRIAL=price_xxx
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx

# Optional: enable Stripe Tax (automatic_tax + tax_id_collection) on checkout.
# Leave UNSET/false unless you have completed Stripe Tax setup (origin address +
# registrations) in the Stripe Dashboard — otherwise Checkout session creation
# fails with a 400 and no subscription is created. Set to "true" only when ready.
STRIPE_AUTOMATIC_TAX=false

# ─── DodoPayments ─────────────────────────────────────────────────────────────
# Alternative payment provider for emerging markets (UPI, PIX, iDEAL, etc.)
# Server-side only — required, validated at runtime.
# Use PRODUCT IDs for subscriptions (e.g., pdt_abc123), not price IDs.
DODOPAYMENTS_API_KEY=dodo_test_your_api_key_here
DODOPAYMENTS_WEBHOOK_SECRET=whsec_xxx

# DodoPayments PRODUCT IDs (different for test vs live mode)
# Example: pdt_fqJhl7pxKWiLhwQR042rh
DODOPAYMENTS_PRODUCT_MONTHLY=pdt_xxx
DODOPAYMENTS_PRODUCT_YEARLY=pdt_xxx

# One-time $5 product for the 5-day trial. REQUIRED to offer the trial on Dodo:
# the trial charges $5 up front (bundled with the first payment) then auto-
# converts to monthly — identical to Stripe. If this is unset, the trial option
# is simply hidden for Dodo (we never create a $0 trial). Run `npm run dodo:setup`
# to create it and paste the id here. Accepts DODO_PAYMENTS_PRODUCT_TRIAL too.
DODOPAYMENTS_PRODUCT_TRIAL=pdt_xxx

# Optional — Brand id controls the logo/branding on the Dodo hosted checkout.
# Example: brnd_xxxxxxxxxxxxxxxxxxxxx
DODOPAYMENTS_BRAND_ID=brnd_xxx

# Optional — Dodo SDK mode. "test_mode" (default) or "live_mode".
# Both DODOPAYMENTS_* and legacy DODO_PAYMENTS_* spellings are accepted.
DODOPAYMENTS_ENVIRONMENT=test_mode

# ─── App Config ───────────────────────────────────────────────────────────────
# IMPORTANT: Update this to your production URL before deploying!
# This is ALSO used to build OAuth redirect URIs. Behind a reverse proxy
# (Render, Fly, etc.) the internal request host is NOT your public domain, so
# this MUST be set to the real public URL or OAuth redirect_uri will be wrong.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional override used specifically for OAuth redirect URIs. If unset,
# NEXT_PUBLIC_APP_URL (and then proxy X-Forwarded-* headers) are used instead.
# OAUTH_BASE_URL=https://talkingo.ai

# Shared secret for admin → web cache invalidation
CACHE_INVALIDATION_SECRET=generate_a_strong_random_string_here

# ─── Required Appwrite collections ────────────────────────────────────────────
# These are created automatically by `npm run db:setup` (recommended). Listed
# here for reference. All payment-related collections are SERVER-ONLY (no client
# read access) — the app reads them only through /api/* routes using the API key.
#
#   subscriptions             Subscription state, one doc per user (SERVER-ONLY)
#   stripe_webhook_events     Webhook idempotency log (doc id = `${provider}:${eventId}`)
#   subscription_events       Subscription status-change audit log (support/forensics)
#   webhook_dead_letter       Webhook failures captured for replay (never lose a payment)
#   free_tier_usage           Lifetime free-message counter, one doc per user (doc id = userId)
#
# If these collections don't exist the app degrades to in-memory tracking and
# you'll see warnings in the server logs — run `npm run db:setup` to provision them.

# ─── Development: WebSocket Server ────────────────────────────────────────────
# In dev, the WebSocket server runs separately on port 3001 so you can use
# `next dev --turbopack` for fast HMR. The client connects via this URL.
# In production, the WS server is bundled into server.ts — leave this unset.
# NEXT_PUBLIC_LIVE_WS_URL=ws://localhost:3001
# LIVE_WS_PORT=3001

# ─── Analytics ────────────────────────────────────────────────────────────────
# Microsoft Clarity — session recordings & heatmaps.
# Find the project id in https://clarity.microsoft.com → Settings → Setup.
NEXT_PUBLIC_CLARITY_ID=your_clarity_project_id_here

# PostHog — product analytics & feature flags.
# Project API key from PostHog → Settings → Project. Safe to expose (public key).
# Host: https://us.i.posthog.com (US cloud) or https://eu.i.posthog.com (EU cloud).
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4 — gtag.js. Measurement id from Google Analytics → Admin →
# Data Streams (format: G-XXXXXXXXXX). Safe to expose to the browser.
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Error Monitoring (Sentry) ────────────────────────────────────────────────
# Leave BOTH DSNs unset to disable Sentry entirely — the SDK becomes a no-op on
# the client, the Next server, the edge runtime, and the standalone WS server.
# DSN from Sentry → Project → Settings → Client Keys (DSN). The same value goes
# in both: NEXT_PUBLIC_ is the browser key, the unprefixed one is server-side.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional. Environment label (defaults to NODE_ENV) and trace sampling rate
# (0..1 — keep low in production to control cost/quota).
# SENTRY_ENV=production
# NEXT_PUBLIC_SENTRY_ENV=production
# SENTRY_TRACES_SAMPLE_RATE=0.1
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Build-time ONLY — required to upload source maps so production stack traces are
# readable. Create at Sentry → Settings → Auth Tokens. DO NOT commit it; without
# it the build still succeeds (it just skips the source-map upload).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=irshame
# SENTRY_PROJECT=javascript-nextjs

# ─── Sentry (error monitoring) ─────────────────────────────────────────────────
# DSN from Sentry → Settings → Projects → <project> → Client Keys (DSN). Safe to
# expose in the browser. Set BOTH (server runtime + browser bundle). Leave empty
# to disable Sentry entirely (the SDK init becomes a no-op).
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Optional — environment label + trace sampling rate (0.0–1.0).
SENTRY_ENV=production
NEXT_PUBLIC_SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# Source-map upload at build time (optional). Org/project default in next.config.
SENTRY_ORG=your_sentry_org
SENTRY_PROJECT=your_sentry_project
# SENTRY_AUTH_TOKEN=your_build_time_auth_token
