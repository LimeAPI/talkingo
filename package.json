{
  "name": "@talkingo/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,ws -c cyan,yellow \"next dev --turbopack\" \"tsx --env-file=.env.local ws-server.ts\"",
    "dev:next": "next dev --turbopack",
    "dev:ws": "tsx --env-file=.env.local ws-server.ts",
    "dev:full": "tsx server.ts",
    "build": "next build",
    "start": "NODE_ENV=production tsx server.ts",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "db:setup": "node --env-file=.env.local --import tsx scripts/setup-appwrite-schema.ts",
    "db:backfill-subscriptions": "node --env-file=.env.local --import tsx scripts/backfill-subscription-canonical.ts",
    "db:reset-dev": "node --env-file=.env.local --import tsx scripts/reset-dev-data.ts",
    "db:remove-system-config": "node --env-file=.env.local --import tsx scripts/remove-system-config.ts",
    "stripe:setup": "node --env-file=.env.local --import tsx scripts/setup-stripe-products.ts",
    "dodo:setup": "node --env-file=.env.local --import tsx scripts/setup-dodo-products.ts",
    "generate-icons": "node scripts/create-png-icons.js",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@microsoft/clarity": "^1.0.2",
    "@sentry/nextjs": "^10.62.0",
    "@sentry/node": "^10.62.0",
    "appwrite": "^16.1.0",
    "bufferutil": "^4.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dodopayments": "^2.34.0",
    "dompurify": "^3.4.8",
    "framer-motion": "^12.40.0",
    "lucide-react": "^0.469.0",
    "msedge-tts": "^2.0.5",
    "next": "15.5.18",
    "next-intl": "4.13.0",
    "next-themes": "^0.4.6",
    "node-appwrite": "^14.2.0",
    "posthog-js": "^1.393.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7",
    "stripe": "^22.2.1",
    "tailwind-merge": "^2.6.1",
    "tailwindcss-animate": "^1.0.7",
    "utf-8-validate": "^6.0.6",
    "ws": "^8.18.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^10.0.3",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.18",
    "fast-check": "^4.8.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "shadcn": "^4.8.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "~5.7.0",
    "vitest": "^4.1.9"
  }
}
